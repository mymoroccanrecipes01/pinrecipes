# ── Protections sécurité ─────────────────────────────────────────────────────

# Bloquer l'accès direct aux fichiers de configuration sensibles
<FilesMatch "^(site-config\.json|prompts\.json|settings\.json|profiles\.json|push-debug\.log)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Bloquer l'accès direct aux scripts PHP internes (API, auth, pipeline)
<FilesMatch "^(config\.php|auth\.php|central-auth\.php|central-login\.php|auto-pipeline\.php|auto-daily-csv\.php|git-init-api\.php|tasks-api\.php|fb-auto-post\.php|yt-auto-post\.php)$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Bloquer l'accès aux logs
<FilesMatch "\.log$">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# Empêcher la navigation dans les répertoires
Options -Indexes

# ── Activation du module de réécriture ───────────────────────────────────────
RewriteEngine On

# ── SEO : X-Robots-Tag noindex sur routes SPA shell (/base, ?page=) ─────────
<IfModule mod_rewrite.c>
    # ?page= query string → SPA shell vide pour les bots
    RewriteCond %{QUERY_STRING} (^|&)page=
    RewriteRule ^ - [E=NOINDEX:1,L]

    # /base et /base.html → SPA shell vide
    RewriteCond %{REQUEST_URI} ^/base(\.html)?(/|$)
    RewriteRule ^ - [E=NOINDEX:1,L]
</IfModule>
<IfModule mod_headers.c>
    Header always set X-Robots-Tag "noindex, follow" env=NOINDEX
</IfModule>

# ── SEO : redirect trailing slash pour /posts/{slug} → /posts/{slug}/ ────────
<IfModule mod_rewrite.c>
    # Eviter les fichiers statiques existants
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    # /posts/slug (sans slash) → /posts/slug/ (avec slash — URL canonique)
    RewriteCond %{REQUEST_URI} ^/posts/[^/]+$
    RewriteRule ^(posts/.+)$ /$1/ [R=301,L]
</IfModule>

# ── RSS : fichiers XML dans /rss/ ────────────────────────────────────────────
<IfModule mod_rewrite.c>
    RewriteCond %{REQUEST_FILENAME} -f
    RewriteRule ^rss/(.+\.xml)$ rss/$1 [L]
</IfModule>

# Configuration pour permettre l'accès aux fichiers XML
<FilesMatch "\.xml$">
    Header set Content-Type "application/rss+xml; charset=UTF-8"
    Header set Access-Control-Allow-Origin "*"
</FilesMatch>

# Cache pour les flux RSS (1 heure)
<IfModule mod_expires.c>
    <FilesMatch "\.xml$">
        ExpiresActive On
        ExpiresDefault "access plus 1 hour"
    </FilesMatch>
</IfModule>
